{
  "name": "teeahead",
  "crons": [
    {
      "path": "/api/crm/stale-leads",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/referral-payouts",
      "schedule": "0 9 1 * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "teeahead.com" }],
      "destination": "https://www.teeahead.com/:path*",
      "permanent": true
    }
  ]
}
